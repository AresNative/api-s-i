<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- 1. Remover módulos que bloquean PUT/DELETE -->
      <modules>
        <remove name="WebDAVModule" />
        <remove name="WebDAV" />
      </modules>
      
      <!-- 2. Configurar handlers para permitir todos los verbos -->
      <handlers>
        <remove name="WebDAV" />
        <remove name="WebDAVModule" />
        <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
        <remove name="OPTIONSVerbHandler" />
        <remove name="StaticFile" />
        
        <!-- Handler principal para ASP.NET Core -->
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
        
        <!-- Handler para URLs sin extensión -->
        <add name="ExtensionlessUrlHandler-Integrated-4.0" 
             path="*." 
             verb="GET,HEAD,POST,DEBUG,PUT,DELETE,PATCH,OPTIONS" 
             type="System.Web.Handlers.TransferRequestHandler" 
             preCondition="integratedMode,runtimeVersionv4.0" />
      </handlers>

      <!-- 3. Configurar filtrado de solicitudes para permitir PUT/DELETE -->
      <security>
        <requestFiltering>
          <verbs allowUnlisted="true">
            <add verb="PUT" allowed="true" />
            <add verb="DELETE" allowed="true" />
            <add verb="PATCH" allowed="true" />
            <add verb="OPTIONS" allowed="true" />
          </verbs>
           <fileExtensions>
            <add fileExtension="." allowed="true" />
            <!-- Permitir extensiones de archivos estáticos -->
            <add fileExtension=".jpeg" allowed="true" />
            <add fileExtension=".jpg" allowed="true" />
            <add fileExtension=".png" allowed="true" />
            <add fileExtension=".gif" allowed="true" />
            <add fileExtension=".webp" allowed="true" />
            <add fileExtension=".svg" allowed="true" />
            <add fileExtension=".bmp" allowed="true" />
            <add fileExtension=".pdf" allowed="true" />
            <add fileExtension=".doc" allowed="true" />
            <add fileExtension=".docx" allowed="true" />
            <add fileExtension=".xls" allowed="true" />
            <add fileExtension=".xlsx" allowed="true" />
          </fileExtensions>
        </requestFiltering>
      </security>

      <!-- 4. Configuración para archivos estáticos -->
      <staticContent>
        <!-- MIME Types para imágenes -->
        <mimeMap fileExtension=".jpeg" mimeType="image/jpeg" />
        <mimeMap fileExtension=".jpg" mimeType="image/jpeg" />
        <mimeMap fileExtension=".png" mimeType="image/png" />
        <mimeMap fileExtension=".gif" mimeType="image/gif" />
        <mimeMap fileExtension=".webp" mimeType="image/webp" />
        <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
        <mimeMap fileExtension=".bmp" mimeType="image/bmp" />
      </staticContent>

      <!-- 5. Configurar cabeceras CORS -->
      <httpProtocol>
        <customHeaders>
          <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, PATCH, OPTIONS" />
        </customHeaders>
      </httpProtocol>

      <!-- 6. Configuración de ASP.NET Core -->
      <aspNetCore processPath="dotnet" arguments=".\API_Website.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
<!--ProjectGuid: B7CCBCE6-7EA2-4BE9-A73C-5299B05B499C-->